# R session artefacts
.Rproj.user
.Rhistory
.RData
.Ruserdata
.Renviron

# Pipeline scratch outputs (canonical data lives on OneDrive, not in git)
data/**
!data/.gitkeep

# Downloaded documents (large binaries; corpus lives in OneDrive Data/Project_doc)
downloads/**
!downloads/.gitkeep

# Generated reports and logs
reports/
logs/*.csv

# OS junk
Thumbs.db
desktop.ini
.DS_Store

# Keep placeholder files so empty folders are tracked
!docs/.gitkeep
!tests/.gitkeep
